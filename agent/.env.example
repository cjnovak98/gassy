# Agent role: engineer | mayor
AGENT_ROLE=engineer

# Port for A2A server (default 8082)
PORT=8082

# Supervisor URL for registration (default http://localhost:9091)
SUPERVISOR_URL=http://localhost:9091

# MiniMax API credentials
ANTHROPIC_AUTH_TOKEN=your_key_here
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7